# Database Configuration
DB_HOST=localhost
DB_NAME=rps_generator
DB_USER=root
DB_PASS=

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_SECURE=tls
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=RPS Generator AI
SMTP_DEBUG=true

# Security Configuration (Gunakan string acak 32-karakter)
ENCRYPTION_KEY=your-32-char-random-key-here

# Check-Mail.org API Key (Opsional - Deteksi email palsu/disposable)
CHECK_MAIL_API_KEY=
